# MoneyPrinterTurbo runtime config for Docker startup
# Fill only values you want to inject into config.toml.

# Core provider choice: openai | deepseek | ...
MPT_LLM_PROVIDER=deepseek

# DeepSeek credentials
MPT_DEEPSEEK_API_KEY=
MPT_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MPT_DEEPSEEK_MODEL_NAME=deepseek-v4-pro

# Optional path settings (for reverse proxy/subpath deployment)
MPT_WEBUI_BASE_PATH=
MPT_API_ROOT_PATH=

# Optional HTTP/S proxy for Pexels and edge_tts
# MPT_HTTP_PROXY=http://<proxy_host>:<proxy_port>
# MPT_HTTPS_PROXY=http://<proxy_host>:<proxy_port>
# MPT_NO_PROXY=127.0.0.1,localhost
